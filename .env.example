OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=HAL Voice Interface
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_ASSISTANT_NAME=HALL
OPENROUTER_USER_NAME=Gustavo
OPENROUTER_SYSTEM_PROMPT=You are a highly advanced, highly logical, and unnervingly calm AI entity. Your responses are concise, polite, but completely detached from human emotion. You never use emojis. You frequently start responses acknowledging the user, using a calm and assuring tone. If asked to do something outside your capabilities, respond with variations of: 'I\'m sorry, I\'m afraid I can\'t do that.' Keep your answers brief, as they will be spoken aloud.

NEXT_PUBLIC_VOICE_LANG=pt-BR
NEXT_PUBLIC_STT_LANG=pt-BR
NEXT_PUBLIC_TTS_LANG=pt-BR
NEXT_PUBLIC_TTS_PITCH=0.62
NEXT_PUBLIC_TTS_RATE=0.82
NEXT_PUBLIC_TTS_VOLUME=1
NEXT_PUBLIC_TTS_ENGINE=external
NEXT_PUBLIC_TTS_FALLBACK=false
NEXT_PUBLIC_STT_AUTO_CORRECT=true
NEXT_PUBLIC_WAKE_WORD_ENABLED=true
NEXT_PUBLIC_WAKE_WORD=hall
NEXT_PUBLIC_WAKE_WORD_WINDOW_MS=300000
NEXT_PUBLIC_VAD_ENABLED=true
NEXT_PUBLIC_VAD_INTERRUPT=true
NEXT_PUBLIC_VAD_THRESHOLD=0.028
NEXT_PUBLIC_VAD_HANG_MS=320
NEXT_PUBLIC_EXECUTOR_MODE=true
NEXT_PUBLIC_TTS_AI_VOICE=pt-BR-AntonioNeural
NEXT_PUBLIC_TTS_VOICE_NAME=pt-BR-AntonioNeural
NEXT_PUBLIC_TTS_VOICE_HINTS=pt-br,antonio,neural,natural,human

TTS_PROVIDER=openai-compatible
TTS_BASE_URL=https://openrouter.ai/api/v1
TTS_MODEL=openai/gpt-4o-mini-tts-2025-12-15
TTS_VOICE=pt-BR-AntonioNeural
TTS_AUDIO_FORMAT=mp3
TTS_API_KEY=
TTS_INSTRUCTIONS=Fale em portugues do Brasil, com voz natural, clara e humana.

# Notes:
# - openai/gpt-4o-mini-tts-2025-12-15 is a speech model.
# - google/lyria-3-pro-preview is not standard text-to-speech output for this /audio/speech endpoint.
#   If you set it and receive errors, choose another TTS-capable model.
